<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Walkie Talkie - PTT sin  cortes</title>
    <style>
        *{user-select:none;-webkit-tap-highlight-color:transparent}
        body{margin:0;min-height:100vh;background:linear-gradient(135deg,#0a0a0f,#1a1a2e);font-family:'Segoe UI',sans-serif;display:flex;justify-content:center;align-items:center;padding:20px}
        .container{max-width:500px;width:100%}
        .walkie{background:#2c2c3e;border-radius:40px;padding:25px;box-shadow:0 20px 40px rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.1)}
        h1{text-align:center;color:#ff6b6b;margin:0 0 5px;font-size:1.6rem}
        .subtitle{text-align:center;color:#2ed573;font-size:.7rem;margin-bottom:20px}
        
        .walkie-selector{display:flex;gap:15px;margin-bottom:20px}
        .walkie-option{flex:1;text-align:center;padding:15px;background:#1e1e2a;border-radius:20px;cursor:pointer;border:2px solid transparent}
        .walkie-option.selected{border-color:#2ed573;background:#2ed57322}
        .walkie-num{font-size:2rem;font-weight:bold}
        .walkie-status{font-size:.7rem;margin-top:5px}
        .walkie-id{font-size:.6rem;color:#888;margin-top:3px;word-break:break-all}
        
        .panel{background:#1e1e2a;border-radius:20px;padding:15px;margin-bottom:20px}
        button{width:100%;padding:12px;background:#ff6b6b;border:none;border-radius:12px;color:white;font-weight:bold;cursor:pointer;margin-bottom:10px}
        button.reset{background:#ffa502}
        button.reset-all{background:#e74c3c}
        button.modo{background:#2ed573}
        
        .modo-indicador{background:#0a0a0f;border-radius:15px;padding:10px;margin-bottom:15px;text-align:center}
        .modo-texto{font-size:.9rem;font-weight:bold}
        .modo-texto.walkie{color:#ff6b6b}
        .modo-texto.manoslibres{color:#2ed573}
        
        .ptt-button{width:180px;height:180px;border-radius:50%;background:radial-gradient(#e74c3c,#c0392b);border:4px solid #ecf0f1;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-direction:column;font-size:1.2rem;font-weight:bold;color:white;margin:20px auto;transition:.05s linear}
        .ptt-button:active{transform:scale(.96)}
        .ptt-button.listening{background:radial-gradient(#34495e,#2c3e50)}
        .ptt-button.disabled{opacity:0.5;pointer-events:none}
        
        .status{background:#000000aa;border-radius:15px;padding:15px;text-align:center;margin-top:15px}
        .status-value{font-size:1.2rem;font-weight:bold;display:flex;align-items:center;justify-content:center;gap:10px}
        .status-value.listening{color:#2ed573}
        .status-value.speaking{color:#ff4757}
        .led{width:12px;height:12px;border-radius:50%;animation:pulse 1s infinite}
        .led.listening{background:#2ed573}
        .led.speaking{background:#ff4757}
        
        .sync-status{font-size:.7rem;text-align:center;margin-top:10px;padding:8px;border-radius:10px}
        .sync-status.success{background:#2ed57322;color:#2ed573}
        .sync-status.error{background:#ff475722;color:#ff4757}
        .sync-status.waiting{background:#ffa50222;color:#ffa502}
        
        @keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
        .info-text{font-size:.7rem;color:#888;text-align:center;margin-top:15px}
        .toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#2ed573;color:#0a0a0f;padding:10px 20px;border-radius:30px;font-size:.8rem;font-weight:bold;z-index:1000;animation:slideUp 0.3s ease}
        @keyframes slideUp{from{opacity:0;transform:translateX(-50%) translateY(20px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
    </style>
</head>
<body>
<div class="container">
    <div class="walkie">
        <h1>📞 WALKIE TALKIE</h1>
        <div class="subtitle">PTT sin cortes - Llamada permanente</div>

        <div class="walkie-selector">
            <div class="walkie-option w1" id="walkie1">
                <div class="walkie-num">📻 1</div>
                <div class="walkie-status" id="status1">Cargando...</div>
                <div class="walkie-id" id="id1">---</div>
            </div>
            <div class="walkie-option w2" id="walkie2">
                <div class="walkie-num">📻 2</div>
                <div class="walkie-status" id="status2">Cargando...</div>
                <div class="walkie-id" id="id2">---</div>
            </div>
        </div>

        <div class="panel">
            <div class="modo-indicador">
                <div class="modo-texto walkie" id="modoTexto">📻 MODO WALKIE (PTT)</div>
                <button id="cambiarModo" class="modo">🔄 CAMBIAR A MANOS LIBRES</button>
            </div>
            
            <button id="resetWalkie" class="reset">🔄 RESET MI WALKIE (nuevo ID)</button>
            <button id="resetAll" class="reset-all">⚠️ RESET TOTAL (nuevos IDs para ambos)</button>
        </div>

        <div id="boton" class="ptt-button listening disabled">🎧<br>SIN ASIGNAR</div>

        <div class="status">
            <div class="status-value listening" id="miEstado">
                <span class="led listening"></span>ESCUCHANDO
            </div>
            <div id="hablante" style="font-size:.8rem;margin-top:5px;color:#ff4757;display:none;"></div>
        </div>
        
        <div class="sync-status waiting" id="estado">📡 Inicializando...</div>
        <div class="info-text">
            <strong>📌 CÓMO USAR:</strong><br>
            1. Elige WALKIE 1 o WALKIE 2<br>
            2. El otro usuario elige el otro walkie<br>
            3. 📻 MODO WALKIE: Mantén el botón ROJO para hablar (sin cortes)<br>
            4. 🎤 MODO MANOS LIBRES: Micrófono siempre abierto (usa auriculares)
        </div>
    </div>
</div>

<script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
<script>
// ============ TOKEN CAMUFLADO ============
const TOKEN_CAMUFLADO = "sexta_xLLoYGcLcibBLCrvC1tbCE8S7kxRKf16Xp52tahola";

function obtenerTokenReal() {
    return TOKEN_CAMUFLADO
        .replace("sexta_", "ghp_")
        .replace("hola", "");
}

const GITHUB_TOKEN = obtenerTokenReal();
console.log("✅ Token cargado");

// ============ CONFIGURACIÓN ============
const GITHUB_OWNER = 'landrasystem-star';
const GITHUB_REPO = 'walkie';
// =======================================

let peer = null;
let miId = null;
let miWalkie = null;
let miStream = null;
let hablando = false;
let llamadaActiva = null;
let audioElement = null;
let otroId = null;
let intervalo = null;
let modoManosLibres = false;

let currentWalkie1Id = null;
let currentWalkie2Id = null;

function mostrarToast(mensaje, esError = false) {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.textContent = mensaje;
    toast.style.background = esError ? '#ff4757' : '#2ed573';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2000);
}

function generarIdUnico() {
    return 'w' + Date.now() + '_' + Math.random().toString(36).substring(2, 10);
}

// ============ GITHUB SYNC ============
async function leerConfiguracion() {
    try {
        const res = await fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/walkie_config.json`, {
            headers: { 'Authorization': `token ${GITHUB_TOKEN}` }
        });
        if (res.status === 404) return { walkie1_id: null, walkie2_id: null, ocupado1: null, ocupado2: null };
        if (!res.ok) return {};
        const data = await res.json();
        return JSON.parse(atob(data.content));
    } catch(e) {
        console.error('Error:', e);
        return {};
    }
}

async function guardarConfiguracion(config) {
    const contenido = btoa(unescape(encodeURIComponent(JSON.stringify(config, null, 2))));
    let sha = null;
    try {
        const res = await fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/walkie_config.json`, {
            headers: { 'Authorization': `token ${GITHUB_TOKEN}` }
        });
        if (res.ok) sha = (await res.json()).sha;
    } catch(e) {}
    
    await fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/walkie_config.json`, {
        method: 'PUT',
        headers: { 'Authorization': `token ${GITHUB_TOKEN}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: 'update', content: contenido, sha })
    });
}

async function inicializarConfiguracion() {
    let config = await leerConfiguracion();
    let cambio = false;
    
    if (!config.walkie1_id) {
        config.walkie1_id = generarIdUnico();
        cambio = true;
    }
    if (!config.walkie2_id) {
        config.walkie2_id = generarIdUnico();
        cambio = true;
    }
    if (!config.ocupado1) config.ocupado1 = null;
    if (!config.ocupado2) config.ocupado2 = null;
    
    if (cambio) {
        await guardarConfiguracion(config);
    }
    
    currentWalkie1Id = config.walkie1_id;
    currentWalkie2Id = config.walkie2_id;
    
    document.getElementById('id1').innerHTML = currentWalkie1Id ? `ID: ${currentWalkie1Id.substring(0, 14)}...` : '---';
    document.getElementById('id2').innerHTML = currentWalkie2Id ? `ID: ${currentWalkie2Id.substring(0, 14)}...` : '---';
    
    return config;
}

async function resetWalkie(walkie) {
    const config = await leerConfiguracion();
    const nuevoId = generarIdUnico();
    
    if (walkie === 'walkie1') {
        config.walkie1_id = nuevoId;
        config.ocupado1 = null;
        currentWalkie1Id = nuevoId;
    } else {
        config.walkie2_id = nuevoId;
        config.ocupado2 = null;
        currentWalkie2Id = nuevoId;
    }
    
    await guardarConfiguracion(config);
    
    if (miWalkie === walkie) {
        if (peer) peer.destroy();
        setTimeout(() => iniciarPeerConId(miWalkie, nuevoId), 500);
    }
    
    document.getElementById('id1').innerHTML = currentWalkie1Id ? `ID: ${currentWalkie1Id.substring(0, 14)}...` : '---';
    document.getElementById('id2').innerHTML = currentWalkie2Id ? `ID: ${currentWalkie2Id.substring(0, 14)}...` : '---';
    
    mostrarToast(`✅ Walkie ${walkie === 'walkie1' ? '1' : '2'} tiene NUEVO ID`);
    await actualizarUI();
}

async function resetTotal() {
    const nuevoId1 = generarIdUnico();
    const nuevoId2 = generarIdUnico();
    
    const config = {
        walkie1_id: nuevoId1,
        walkie2_id: nuevoId2,
        ocupado1: null,
        ocupado2: null,
        ultimoReset: Date.now()
    };
    
    await guardarConfiguracion(config);
    currentWalkie1Id = nuevoId1;
    currentWalkie2Id = nuevoId2;
    
    if (miWalkie === 'walkie1') {
        if (peer) peer.destroy();
        setTimeout(() => iniciarPeerConId('walkie1', nuevoId1), 500);
    } else if (miWalkie === 'walkie2') {
        if (peer) peer.destroy();
        setTimeout(() => iniciarPeerConId('walkie2', nuevoId2), 500);
    }
    
    document.getElementById('id1').innerHTML = currentWalkie1Id ? `ID: ${currentWalkie1Id.substring(0, 14)}...` : '---';
    document.getElementById('id2').innerHTML = currentWalkie2Id ? `ID: ${currentWalkie2Id.substring(0, 14)}...` : '---';
    
    mostrarToast(`🔄 RESET TOTAL: IDs nuevos generados`);
    await actualizarUI();
}

async function ocuparWalkie(walkie) {
    const config = await leerConfiguracion();
    const walkieId = walkie === 'walkie1' ? config.walkie1_id : config.walkie2_id;
    
    if (!walkieId) {
        mostrarToast(`Error: Walkie sin ID. Haz RESET TOTAL`, true);
        return false;
    }
    
    const ocupado = walkie === 'walkie1' ? config.ocupado1 : config.ocupado2;
    if (ocupado && ocupado.peerId !== miId && (Date.now() - (ocupado.timestamp || 0)) < 15000) {
        mostrarToast(`❌ Walkie ${walkie === 'walkie1' ? '1' : '2'} ya está ocupado`, true);
        return false;
    }
    
    if (walkie === 'walkie1') {
        config.ocupado1 = { peerId: miId, timestamp: Date.now(), hablando: false };
    } else {
        config.ocupado2 = { peerId: miId, timestamp: Date.now(), hablando: false };
    }
    
    await guardarConfiguracion(config);
    return true;
}

async function liberarWalkie(walkie) {
    const config = await leerConfiguracion();
    if (walkie === 'walkie1') {
        config.ocupado1 = null;
    } else {
        config.ocupado2 = null;
    }
    await guardarConfiguracion(config);
}

async function actualizarUI() {
    const config = await leerConfiguracion();
    
    const status1 = document.getElementById('status1');
    const status2 = document.getElementById('status2');
    
    if (config.ocupado1) {
        status1.innerHTML = `👤 Ocupado<br>🟢 Online`;
        if (miWalkie === 'walkie1') document.getElementById('walkie1').classList.add('selected');
        else document.getElementById('walkie1').classList.remove('selected');
    } else {
        status1.innerHTML = `🔓 Libre`;
        document.getElementById('walkie1').classList.remove('selected');
    }
    
    if (config.ocupado2) {
        status2.innerHTML = `👤 Ocupado<br>🟢 Online`;
        if (miWalkie === 'walkie2') document.getElementById('walkie2').classList.add('selected');
        else document.getElementById('walkie2').classList.remove('selected');
    } else {
        status2.innerHTML = `🔓 Libre`;
        document.getElementById('walkie2').classList.remove('selected');
    }
    
    const otroWalkie = miWalkie === 'walkie1' ? 'walkie2' : 'walkie1';
    const ocupadoOtro = otroWalkie === 'walkie1' ? config.ocupado1 : config.ocupado2;
    
    if (ocupadoOtro && ocupadoOtro.peerId) {
        const nuevoOtroId = ocupadoOtro.peerId;
        
        // Si el otro ID cambió, reconectar la llamada
        if (otroId !== nuevoOtroId) {
            otroId = nuevoOtroId;
            if (!modoManosLibres && llamadaActiva) {
                llamadaActiva.close();
                llamadaActiva = null;
            }
        }
        
        document.getElementById('estado').innerHTML = `✅ Conectado al Walkie ${otroWalkie === 'walkie1' ? '1' : '2'}`;
        document.getElementById('estado').className = 'sync-status success';
        document.getElementById('boton').classList.remove('disabled');
        
        // Establecer llamada permanente si no existe (para PTT)
        if (!modoManosLibres && !llamadaActiva && miStream && otroId) {
            const call = peer.call(otroId, miStream);
            llamadaActiva = call;
            call.on('stream', (stream) => {
                if (audioElement) audioElement.pause();
                audioElement = new Audio();
                audioElement.srcObject = stream;
                audioElement.autoplay = true;
            });
            // Iniciar con micrófono silenciado
            if (miStream) {
                miStream.getAudioTracks().forEach(track => {
                    track.enabled = false;
                });
            }
        }
        
        // Actualizar estado visual del otro
        if (ocupadoOtro.hablando && !hablando && !modoManosLibres) {
            document.getElementById('hablante').innerHTML = `🎤 El otro walkie está hablando...`;
            document.getElementById('hablante').style.display = 'block';
        } else if (!ocupadoOtro.hablando) {
            document.getElementById('hablante').style.display = 'none';
        }
    } else {
        otroId = null;
        document.getElementById('estado').innerHTML = `⏳ Esperando al otro walkie...`;
        document.getElementById('estado').className = 'sync-status waiting';
        document.getElementById('boton').classList.add('disabled');
        if (llamadaActiva) {
            llamadaActiva.close();
            llamadaActiva = null;
        }
    }
}

async function actualizarMiEstadoEnGitHub() {
    if (!miWalkie || !miId) return;
    const config = await leerConfiguracion();
    const ocupado = miWalkie === 'walkie1' ? config.ocupado1 : config.ocupado2;
    if (ocupado && ocupado.peerId === miId) {
        ocupado.hablando = hablando;
        ocupado.timestamp = Date.now();
        if (miWalkie === 'walkie1') {
            config.ocupado1 = ocupado;
        } else {
            config.ocupado2 = ocupado;
        }
        await guardarConfiguracion(config);
    }
}

// ============ PEERJS ============
function iniciarPeerConId(walkie, peerIdFijo) {
    if (peer) peer.destroy();
    
    if (!peerIdFijo) {
        mostrarToast(`Error: No hay ID`, true);
        return;
    }
    
    peer = new Peer(peerIdFijo, { host: '0.peerjs.com', port: 443, secure: true });
    
    peer.on('open', async (id) => {
        miId = id;
        console.log('✅ Peer:', id);
        await ocuparWalkie(miWalkie);
        document.getElementById('boton').classList.remove('disabled');
        actualizarMiEstadoEnGitHub();
        mostrarToast(`✅ Walkie ${miWalkie === 'walkie1' ? '1' : '2'} conectado`);
    });
    
    peer.on('call', (call) => {
        if (!miStream) return;
        call.answer(miStream);
        call.on('stream', (stream) => {
            if (audioElement) audioElement.pause();
            audioElement = new Audio();
            audioElement.srcObject = stream;
            audioElement.autoplay = true;
        });
    });
    
    peer.on('error', (err) => {
        console.error('Error:', err);
        if (err.type === 'unavailable-id') {
            mostrarToast(`⚠️ ID en uso. Usa RESET`, true);
        }
    });
}

// ============ MODO MANOS LIBRES ============
async function cambiarModo() {
    modoManosLibres = !modoManosLibres;
    
    const modoTexto = document.getElementById('modoTexto');
    const botonModo = document.getElementById('cambiarModo');
    const botonPTT = document.getElementById('boton');
    
    if (modoManosLibres) {
        modoTexto.innerHTML = '🎤 MODO MANOS LIBRES (siempre hablando)';
        modoTexto.className = 'modo-texto manoslibres';
        botonModo.innerHTML = '🔄 CAMBIAR A MODO WALKIE (PTT)';
        
        // Activar micrófono siempre
        if (miStream) {
            miStream.getAudioTracks().forEach(track => {
                track.enabled = true;
            });
        }
        if (miStream && otroId) {
            if (llamadaActiva) llamadaActiva.close();
            hablando = true;
            const call = peer.call(otroId, miStream);
            llamadaActiva = call;
            document.getElementById('miEstado').innerHTML = '<span class="led speaking"></span>MANOS LIBRES (ON)';
            document.getElementById('miEstado').classList.remove('listening');
            await actualizarMiEstadoEnGitHub();
        }
        mostrarToast('🎤 Modo Manos Libres - micrófono siempre abierto');
    } else {
        modoTexto.innerHTML = '📻 MODO WALKIE (PTT - pulsar para hablar)';
        modoTexto.className = 'modo-texto walkie';
        botonModo.innerHTML = '🔄 CAMBIAR A MANOS LIBRES';
        
        // Silenciar micrófono y mantener llamada
        if (miStream) {
            miStream.getAudioTracks().forEach(track => {
                track.enabled = false;
            });
        }
        hablando = false;
        document.getElementById('miEstado').innerHTML = '<span class="led listening"></span>ESCUCHANDO';
        document.getElementById('miEstado').classList.add('listening');
        await actualizarMiEstadoEnGitHub();
        mostrarToast('📻 Modo Walkie - mantén botón para hablar (sin cortes)');
    }
}

// ============ PTT CORREGIDO (sin cortes) ============
async function empezarHablarPTT() {
    if (modoManosLibres) return;
    
    if (!miStream) {
        mostrarToast('Micrófono no disponible', true);
        return;
    }
    if (!miWalkie || !otroId) {
        mostrarToast('Espera al otro walkie', true);
        return;
    }
    
    hablando = true;
    
    // Activar el micrófono (quitar silencio)
    if (miStream) {
        miStream.getAudioTracks().forEach(track => {
            track.enabled = true;
        });
    }
    
    const botonPTT = document.getElementById('boton');
    botonPTT.classList.remove('listening');
    botonPTT.innerHTML = '🎤<br>HABLANDO';
    document.getElementById('miEstado').innerHTML = '<span class="led speaking"></span>HABLANDO';
    document.getElementById('miEstado').classList.remove('listening');
    
    await actualizarMiEstadoEnGitHub();
    
    // Si no hay llamada activa, crearla (solo una vez)
    if (!llamadaActiva && miStream && otroId) {
        const call = peer.call(otroId, miStream);
        llamadaActiva = call;
        call.on('stream', (stream) => {
            if (audioElement) audioElement.pause();
            audioElement = new Audio();
            audioElement.srcObject = stream;
            audioElement.autoplay = true;
        });
    }
}

function pararHablarPTT() {
    if (modoManosLibres) return;
    if (!hablando) return;
    
    hablando = false;
    
    // Silenciar el micrófono (pero mantener la llamada)
    if (miStream) {
        miStream.getAudioTracks().forEach(track => {
            track.enabled = false;
        });
    }
    
    const botonPTT = document.getElementById('boton');
    botonPTT.classList.add('listening');
    botonPTT.innerHTML = '🎧<br>ESCUCHANDO';
    document.getElementById('miEstado').innerHTML = '<span class="led listening"></span>ESCUCHANDO';
    document.getElementById('miEstado').classList.add('listening');
    
    actualizarMiEstadoEnGitHub();
    
    // NO cerrar la llamada, solo silenciar el micrófono
}

// ============ SELECCIONAR WALKIE ============
async function seleccionarWalkie(walkie) {
    if (miWalkie === walkie) return;
    
    let config = await leerConfiguracion();
    let walkieId = walkie === 'walkie1' ? config.walkie1_id : config.walkie2_id;
    
    if (!walkieId) {
        walkieId = generarIdUnico();
        if (walkie === 'walkie1') {
            config.walkie1_id = walkieId;
            currentWalkie1Id = walkieId;
        } else {
            config.walkie2_id = walkieId;
            currentWalkie2Id = walkieId;
        }
        await guardarConfiguracion(config);
        document.getElementById('id1').innerHTML = currentWalkie1Id ? `ID: ${currentWalkie1Id.substring(0, 14)}...` : '---';
        document.getElementById('id2').innerHTML = currentWalkie2Id ? `ID: ${currentWalkie2Id.substring(0, 14)}...` : '---';
    }
    
    if (miWalkie) {
        await liberarWalkie(miWalkie);
        if (llamadaActiva) {
            llamadaActiva.close();
            llamadaActiva = null;
        }
        hablando = false;
    }
    
    miWalkie = walkie;
    iniciarPeerConId(walkie, walkieId);
    
    if (intervalo) clearInterval(intervalo);
    intervalo = setInterval(() => {
        if (miWalkie && miId) {
            actualizarMiEstadoEnGitHub();
            actualizarUI();
        }
    }, 3000);
}

// Eventos
document.getElementById('walkie1').onclick = () => seleccionarWalkie('walkie1');
document.getElementById('walkie2').onclick = () => seleccionarWalkie('walkie2');
document.getElementById('resetWalkie').onclick = () => {
    if (miWalkie) resetWalkie(miWalkie);
    else mostrarToast('No tienes walkie asignado', true);
};
document.getElementById('resetAll').onclick = () => resetTotal();
document.getElementById('cambiarModo').onclick = () => cambiarModo();

// PTT
const botonPTT = document.getElementById('boton');
botonPTT.onmousedown = empezarHablarPTT;
botonPTT.onmouseup = pararHablarPTT;
botonPTT.ontouchstart = (e) => { e.preventDefault(); empezarHablarPTT(); };
botonPTT.ontouchend = (e) => { e.preventDefault(); pararHablarPTT(); };

// Inicializar
document.getElementById('estado').innerHTML = '📡 Inicializando...';
document.getElementById('estado').className = 'sync-status waiting';

(async () => {
    try {
        await inicializarConfiguracion();
        await actualizarUI();
        document.getElementById('estado').innerHTML = '✅ Listo - Elige un walkie';
        document.getElementById('estado').className = 'sync-status success';
    } catch(e) {
        document.getElementById('estado').innerHTML = '❌ Error de conexión';
        document.getElementById('estado').className = 'sync-status error';
        mostrarToast('❌ Error al conectar', true);
    }
})();

setInterval(actualizarUI, 5000);

// Pedir micrófono
navigator.mediaDevices.getUserMedia({ audio: true })
    .then(stream => { 
        miStream = stream; 
        // Iniciar con micrófono silenciado para PTT
        stream.getAudioTracks().forEach(track => {
            track.enabled = false;
        });
        mostrarToast('🎙️ Micrófono listo');
    })
    .catch(() => {
        mostrarToast('⚠️ Permite el micrófono', true);
    });

window.addEventListener('beforeunload', () => {
    if (intervalo) clearInterval(intervalo);
    if (miStream) miStream.getTracks().forEach(t => t.stop());
    if (peer) peer.destroy();
    if (miWalkie) liberarWalkie(miWalkie);
});
</script>
</body>
</html>
